@model CreateSliderDto
@{
    ViewData["Title"] = "Yeni Slider Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-11 mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="m-0 font-weight-bold text-primary">Yeni Slider İçeriği Ekle</h5>
                <p class="text-muted small mb-0">Ana sayfadaki slider alanında görünecek bilgileri buradan yönetebilirsiniz.</p>
            </div>

            <div class="card-body p-4">
                <form method="post">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-dark">Slider Başlığı</label>
                            <input type="text" asp-for="Title" class="form-control form-control-lg fs-15 border-secondary-subtle" placeholder="Örn: Hızlı ve Güvenilir Lojistik" required>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-dark">Alt Başlık</label>
                            <input type="text" asp-for="SubTitle" class="form-control form-control-lg fs-15 border-secondary-subtle" placeholder="Örn: 7/24 Kesintisiz Hizmet" required>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-bold text-dark">Görsel URL (ImageUrl)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-light border-secondary-subtle"><i class="mdi mdi-link-variant"></i></span>
                                <input type="text" asp-for="ImageUrl" id="imageUrlInput" class="form-control border-secondary-subtle" placeholder="https://resim-adresi.com/gorsel.jpg" required>
                            </div>

                            <div id="imagePreviewContainer" class="mt-3 d-none">
                                <div class="position-relative d-inline-block">
                                    <img src="" id="imgPreview" alt="Önizleme" class="img-thumbnail shadow-sm" style="max-height: 180px; border: 2px solid #eee;">
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success">Canlı Önizleme</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-bold text-dark">Açıklama Metni</label>
                            <textarea asp-for="Description" class="form-control border-secondary-subtle" rows="4" placeholder="Slider üzerinde yer alacak kısa açıklama yazısı..."></textarea>
                        </div>
                    </div>

                    <hr class="my-4 opacity-25">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Admin/Slider/Index" class="btn btn-light px-4 fw-medium border">Vazgeç</a>
                        <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">
                            <i class="mdi mdi-plus-circle me-1"></i> Slider'ı Sisteme Ekle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const urlInput = document.getElementById('imageUrlInput');
        const previewContainer = document.getElementById('imagePreviewContainer');
        const previewImg = document.getElementById('imgPreview');

        urlInput.addEventListener('input', function () {
            const url = this.value;
            if (url && url.trim() !== '') {
                previewImg.src = url;
                previewContainer.classList.remove('d-none');
            } else {
                previewContainer.classList.add('d-none');
            }
        });

        previewImg.onerror = function() {
            previewContainer.classList.add('d-none');
        };
    </script>
}