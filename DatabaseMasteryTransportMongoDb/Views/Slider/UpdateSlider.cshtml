@model GetSliderByIdDto
@{
	ViewData["Title"] = "Slider Güncelle";
	Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="row">
	<div class="col-lg-11 mx-auto">
		<div class="card shadow-sm border-0">
			<div class="card-header bg-white py-3 border-bottom">
				<h5 class="m-0 font-weight-bold text-primary">Slider İçeriğini Düzenle</h5>
				<p class="text-muted small mb-0">Seçili slider kaydı üzerindeki bilgileri buradan güncelleyebilirsiniz.</p>
			</div>

			<div class="card-body p-4">
				<form method="post">
					<input type="hidden" asp-for="SliderId" />

					<div class="row">
						<div class="col-md-6 mb-4">
							<label class="form-label fw-bold text-dark">Slider Başlığı</label>
							<input type="text" asp-for="Title" class="form-control form-control-lg fs-15 border-secondary-subtle" placeholder="Başlık giriniz..." required>
						</div>

						<div class="col-md-6 mb-4">
							<label class="form-label fw-bold text-dark">Alt Başlık</label>
							<input type="text" asp-for="SubTitle" class="form-control form-control-lg fs-15 border-secondary-subtle" placeholder="Alt başlık giriniz..." required>
						</div>

						<div class="col-md-12 mb-4">
							<label class="form-label fw-bold text-dark">Görsel URL (ImageUrl)</label>
							<div class="input-group shadow-sm">
								<span class="input-group-text bg-light border-secondary-subtle"><i class="mdi mdi-link-variant"></i></span>
								<input type="text" asp-for="ImageUrl" id="imageUrlInput" class="form-control border-secondary-subtle" placeholder="https://resim-adresi.com/gorsel.jpg" required>
							</div>

							<div id="imagePreviewContainer" class="mt-3">
								<div class="position-relative d-inline-block">
									<img src="@Model.ImageUrl" id="imgPreview" alt="Önizleme" class="img-thumbnail shadow-sm" style="max-height: 180px; border: 2px solid #eee;">
									<span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-info">Mevcut Görsel</span>
								</div>
							</div>
						</div>

						<div class="col-md-12 mb-4">
							<label class="form-label fw-bold text-dark">Açıklama Metni</label>
							<textarea asp-for="Description" class="form-control border-secondary-subtle" rows="4" placeholder="Açıklama yazınız..."></textarea>
						</div>
					</div>

					<hr class="my-4 opacity-25">

					<div class="d-flex justify-content-end gap-2">
						<a href="/Admin/Slider/Index" class="btn btn-light px-4 fw-medium border">Vazgeç</a>
						<button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
							<i class="mdi mdi-refresh me-1"></i> Değişiklikleri Kaydet
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		const urlInput = document.getElementById('imageUrlInput');
		const previewImg = document.getElementById('imgPreview');
		const badge = document.querySelector('.badge');

		urlInput.addEventListener('input', function () {
			const url = this.value;
			if (url && url.trim() !== '') {
				previewImg.src = url;
				badge.textContent = "Yeni Görsel";
				badge.classList.replace('bg-info', 'bg-success');
			}
		});

		previewImg.onerror = function() {
			this.src = 'https://via.placeholder.com/180x120?text=Gecersiz+URL';
		};
	</script>
}