@model List<ResultSliderDto>
@{
    ViewData["Title"] = "Slider Yönetimi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .slider-page {
        font-family: 'DM Sans', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 4px;
    }

    .page-subtitle {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a18;
        color: #f4f3ef;
        border: none;
        border-radius: 100px;
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.18s ease, transform 0.18s ease;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: #333330;
            color: #f4f3ef;
            transform: translateY(-1px);
        }

    .table-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
        overflow: hidden;
    }

    .slider-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'DM Sans', sans-serif;
    }

        .slider-table thead tr {
            background: #f8f7f3;
            border-bottom: 1px solid #f0ede6;
        }

        .slider-table thead th {
            font-size: 11px;
            font-weight: 500;
            color: #888780;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 13px 16px;
        }

        .slider-table tbody tr {
            border-bottom: 1px solid #f4f3ef;
            transition: background 0.12s ease;
        }

            .slider-table tbody tr:last-child {
                border-bottom: none;
            }

            .slider-table tbody tr:hover {
                background: #faf9f7;
            }

        .slider-table td {
            padding: 14px 16px;
            vertical-align: middle;
        }

    .slider-thumb {
        width: 120px;
        height: 68px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid #e8e6e0;
        display: block;
    }

    .slider-thumb-placeholder {
        width: 120px;
        height: 68px;
        border-radius: 8px;
        background: #f4f3ef;
        border: 1px solid #e8e6e0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #b4b2a9;
        font-size: 22px;
    }

    .title-main {
        font-size: 13.5px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 3px;
    }

    .title-sub {
        font-size: 12px;
        color: #888780;
    }

    .desc-text {
        font-size: 12.5px;
        color: #888780;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        max-width: 320px;
    }

    .action-group {
        display: flex;
        justify-content: center;
        gap: 6px;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid;
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s ease;
    }

    .btn-icon-edit {
        border-color: #d3d1c7;
        color: #444441;
    }

        .btn-icon-edit:hover {
            background: #f4f3ef;
            color: #1a1a18;
        }

    .btn-icon-del {
        border-color: #f7c1c1;
        color: #a32d2d;
    }

        .btn-icon-del:hover {
            background: #fcebeb;
            color: #791f1f;
        }

    .table-footer {
        padding: 12px 16px;
        border-top: 1px solid #f0ede6;
        text-align: right;
        font-size: 12px;
        color: #888780;
    }

        .table-footer strong {
            color: #444441;
            font-weight: 600;
        }

    .empty-state {
        padding: 4rem 2rem;
        text-align: center;
    }

    .empty-icon-wrap {
        width: 64px;
        height: 64px;
        background: #f4f3ef;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 24px;
        color: #b4b2a9;
    }

    .empty-state h5 {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 5px;
    }

    .empty-state p {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }
</style>

<div class="slider-page">
    <div class="page-header">
        <div>
            <h3 class="page-title">Slider Yönetimi</h3>
            <p class="page-subtitle">Sistemde kayıtlı olan tüm ana sayfa slider içerikleri aşağıda listelenmiştir.</p>
        </div>
        <a href="/Slider/CreateSlider" class="btn-add">
            <i class="mdi mdi-plus-circle"></i> Yeni Slider Ekle
        </a>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table class="slider-table">
                <thead>
                    <tr>
                        <th style="width: 140px;">Görsel</th>
                        <th>Başlık Bilgileri</th>
                        <th>Açıklama</th>
                        <th style="width: 100px; text-align: center;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@item.ImageUrl"
                                         alt="Slider"
                                         class="slider-thumb"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div class="slider-thumb-placeholder" style="display:none;">
                                        <i class="mdi mdi-image-off-outline"></i>
                                    </div>
                                </td>
                                <td>
                                    <div class="title-main">@item.Title</div>
                                    <div class="title-sub">@item.SubTitle</div>
                                </td>
                                <td>
                                    <div class="desc-text" title="@item.Description">@item.Description</div>
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a href="/Slider/UpdateSlider/@item.SliderId"
                                           class="btn-icon btn-icon-edit"
                                           title="Düzenle">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <button type="button"
                                                onclick="deleteSlider('@item.SliderId')"
                                                class="btn-icon btn-icon-del"
                                                title="Sil">
                                            <i class="mdi mdi-delete-outline"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="empty-state">
                                    <div class="empty-icon-wrap">
                                        <i class="mdi mdi-database-off-outline"></i>
                                    </div>
                                    <h5>Henüz Slider Eklenmemiş</h5>
                                    <p>Yeni slider ekleyerek ana sayfanızı özelleştirmeye başlayabilirsiniz.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-footer">
            Toplam Kayıt: <strong>@Model.Count</strong>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteSlider(id) {
            Swal.fire({
                title: 'Slider\'ı Sil?',
                text: "Bu içerik kalıcı olarak silinecektir.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#a32d2d',
                cancelButtonColor: '#888780',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/Slider/DeleteSlider/" + id;
                }
            });
        }
    </script>
}
