        const now = new Date();
        const pad = n => String(n).padStart(2, '0');
        document.getElementById('createdDateInput').value =
            `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;

        function generateTracking() {
            const prefix = 'TR';
            const nums = Math.floor(Math.random() * 9000000000 + 1000000000);
            document.getElementById('trackingInput').value = prefix + nums;
        }

        function populateCities() {
            const originCitySelect = document.getElementById('originCity');
            const destCitySelect = document.getElementById('destCity');

            const sortedCities = Object.keys(turkeyData).sort((a, b) => a.localeCompare(b, 'tr'));

            sortedCities.forEach(city => {
                const opt1 = new Option(city, city);
                const opt2 = new Option(city, city);
                originCitySelect.add(opt1);
                destCitySelect.add(opt2);
            });
        }

        function setupCityDistrictBinding(cityId, districtId, previewCityId, previewDistrictId) {
            const citySelect = document.getElementById(cityId);
            const districtSelect = document.getElementById(districtId);
            const previewCity = document.getElementById(previewCityId);
            const previewDistrict = document.getElementById(previewDistrictId);

            citySelect.addEventListener('change', function () {
                const selectedCity = this.value;

                districtSelect.innerHTML = '<option value="">İlçe Seçin</option>';
                previewDistrict.textContent = '';

                if (selectedCity && turkeyData[selectedCity]) {
                    districtSelect.disabled = false;
                    previewCity.textContent = selectedCity;

                    turkeyData[selectedCity].forEach(district => {
                        districtSelect.add(new Option(district, district));
                    });
                } else {
                    districtSelect.disabled = true;
                    districtSelect.innerHTML = '<option value="">Önce Şehir Seçin</option>';
                    previewCity.textContent = '—';
                }
            });

            districtSelect.addEventListener('change', function () {
                previewDistrict.textContent = this.value ? `, ${this.value}` : '';
            });
        }

        document.addEventListener("DOMContentLoaded", function() {
            populateCities();

            setupCityDistrictBinding('originCity', 'originDistrict', 'previewOriginCity', 'previewOriginDistrict');

            setupCityDistrictBinding('destCity', 'destDistrict', 'previewDestCity', 'previewDestDistrict');
        });
    </script>
