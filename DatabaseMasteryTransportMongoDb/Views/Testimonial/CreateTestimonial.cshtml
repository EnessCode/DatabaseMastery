@model CreateTestimonialDto
@{
    ViewData["Title"] = "Yeni Referans Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .create-testimonial-page {
        font-family: 'DM Sans', sans-serif;
    }

    .form-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
        overflow: hidden;
        max-width: 860px;
        margin: 0 auto;
    }

    .form-card-header {
        padding: 20px 26px 18px;
        border-bottom: 1px solid #f0ede6;
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .form-header-icon {
        width: 42px;
        height: 42px;
        background: #f4f3ef;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .form-header-icon i {
            font-size: 20px;
            color: #444441;
        }

    .form-header-text h5 {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 3px;
    }

    .form-header-text p {
        font-size: 12.5px;
        color: #888780;
        margin: 0;
    }

    .form-card-body {
        padding: 26px;
    }

    .form-field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #444441;
        margin-bottom: 7px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .form-field-input, .form-field-select {
        width: 100%;
        padding: 10px 14px;
        border-radius: 9px;
        border: 1px solid #d3d1c7;
        font-size: 13.5px;
        color: #1a1a18;
        background: #ffffff;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
        outline: none;
    }

        .form-field-input:focus, .form-field-select:focus {
            border-color: #888780;
            box-shadow: 0 0 0 3px rgba(136, 135, 128, 0.08);
        }

    .form-field-textarea {
        width: 100%;
        padding: 10px 14px;
        border-radius: 9px;
        border: 1px solid #d3d1c7;
        font-size: 13.5px;
        color: #1a1a18;
        background: #ffffff;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        resize: vertical;
        min-height: 110px;
        line-height: 1.6;
    }

    .status-switch-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }

    .custom-switch {
        position: relative;
        display: inline-block;
        width: 42px;
        height: 22px;
    }

        .custom-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider-round {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #d3d1c7;
        transition: .4s;
        border-radius: 34px;
    }

        .slider-round:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .slider-round {
        background-color: #1a1a18;
    }

        input:checked + .slider-round:before {
            transform: translateX(20px);
        }

    .form-divider {
        border: none;
        border-top: 1px solid #f0ede6;
        margin: 24px 0;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .btn-form-cancel {
        padding: 10px 22px;
        border-radius: 9px;
        border: 1px solid #d3d1c7;
        background: transparent;
        color: #444441;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: background 0.15s ease;
    }

    .btn-form-save {
        padding: 10px 26px;
        border-radius: 9px;
        border: none;
        background: #1a1a18;
        color: #f4f3ef;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: all 0.15s ease;
    }

        .btn-form-save:hover {
            background: #333330;
            transform: translateY(-1px);
        }
</style>

<div class="create-testimonial-page">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-header-icon">
                <i class="mdi mdi-comment-quote-outline"></i>
            </div>
            <div class="form-header-text">
                <h5>Yeni Müşteri Yorumu Ekle</h5>
                <p>Referanslarınızdan gelen geri bildirimleri bu panelden sisteme dahil edebilirsiniz.</p>
            </div>
        </div>

        <div class="form-card-body">
            <form method="post">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-field-label">Ad Soyad</label>
                        <input type="text" asp-for="NameSurname" class="form-field-input" placeholder="Örn: Ahmet Yılmaz" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-field-label">Ünvan / Şirket</label>
                        <input type="text" asp-for="Title" class="form-field-input" placeholder="Örn: CEO, Lojistik Müdürü" required />
                    </div>

                    <div class="col-md-8">
                        <label class="form-field-label">Profil Fotoğraf URL</label>
                        <input type="text" asp-for="ImageUrl" class="form-field-input" placeholder="https://resim-adresi.com/avatar.jpg" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-field-label">Değerlendirme Puanı</label>
                        <select asp-for="ReviewScore" class="form-field-select">
                            <option value="5">5 Yıldız - Mükemmel</option>
                            <option value="4">4 Yıldız - Çok İyi</option>
                            <option value="3">3 Yıldız - Orta</option>
                            <option value="2">2 Yıldız - Zayıf</option>
                            <option value="1">1 Yıldız - Kötü</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-field-label">Müşteri Yorumu</label>
                        <textarea asp-for="ReviewDetail" class="form-field-textarea" placeholder="Müşterinin deneyim detaylarını buraya yazınız..."></textarea>
                    </div>

                    <div class="col-12">
                        <label class="status-switch-wrap">
                            <span class="custom-switch">
                                <input type="checkbox" asp-for="Status" checked>
                                <span class="slider-round"></span>
                            </span>
                            <span style="font-size: 13.5px; color: #444441; font-weight: 500;">Sistemde Aktif Olarak Göster</span>
                        </label>
                    </div>
                </div>

                <hr class="form-divider" />

                <div class="form-actions">
                    <a href="/Admin/Testimonial/Index" class="btn-form-cancel">Vazgeç</a>
                    <button type="submit" class="btn-form-save">
                        <i class="mdi mdi-plus-circle"></i> Referansı Sisteme Ekle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>