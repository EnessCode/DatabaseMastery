@model List<DatabaseMasteryTransportMongoDb.Dtos.TestimonialDtos.ResultTestimonialDto>
@{
    ViewData["Title"] = "Referans Yönetimi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .testimonial-page {
        font-family: 'DM Sans', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 4px;
    }

    .page-subtitle {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a18;
        color: #f4f3ef;
        border-radius: 100px;
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-add:hover {
            background: #333330;
            color: #fff;
            transform: translateY(-1px);
        }

    .table-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
        overflow: hidden;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead tr {
            background: #f8f7f3;
            border-bottom: 1px solid #f0ede6;
        }

        .custom-table thead th {
            font-size: 11px;
            font-weight: 500;
            color: #888780;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 13px 16px;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid #f4f3ef;
            transition: background 0.12s ease;
        }

            .custom-table tbody tr:hover {
                background: #faf9f7;
            }

        .custom-table td {
            padding: 14px 16px;
            vertical-align: middle;
        }

    .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #f4f3ef;
    }

    .user-name {
        font-size: 13.5px;
        font-weight: 600;
        color: #1a1a18;
    }

    .user-title {
        font-size: 12px;
        color: #888780;
    }

    .score-badge {
        color: #f2b01e;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .status-pill {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
    }

    .status-active {
        background: #eaf3de !important;
        color: #3b6d11 !important;
    }

    .status-passive {
        background: #fcebeb !important;
        color: #a32d2d !important;
    }

    .action-group {
        display: flex;
        justify-content: flex-end;
        gap: 6px;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid #d3d1c7;
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        color: #444441;
        transition: 0.15s;
    }

    .btn-icon-del {
        border-color: #f7c1c1;
        color: #a32d2d;
    }

        .btn-icon-del:hover {
            background: #fcebeb;
            border-color: #f1b2b2;
        }

    .btn-icon:hover:not(.btn-icon-del) {
        background: #f4f3ef;
    }
</style>

<div class="testimonial-page">
    <div class="page-header">
        <div>
            <h3 class="page-title">Referans & Müşteri Yorumları</h3>
            <p class="page-subtitle">Müşterilerinizin geri bildirimlerini ve puanlarını buradan yönetin.</p>
        </div>
        <a href="/Testimonial/CreateTestimonial" class="btn-add">
            <i class="mdi mdi-plus-circle"></i> Yeni Yorum Ekle
        </a>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Müşteri</th>
                        <th>Yorum Özeti</th>
                        <th>Puan</th>
                        <th>Durum</th>
                        <th style="text-align: right;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="user-info">
                                        <img src="@item.ImageUrl" class="user-avatar" onerror="this.src='/images/default-user.png'" />
                                        <div>
                                            <div class="user-name">@item.NameSurname</div>
                                            <div class="user-title">@item.Title</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size:12.5px; color:#666; max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@item.ReviewDetail">
                                        @item.ReviewDetail
                                    </div>
                                </td>
                                <td>
                                    <div class="score-badge">
                                        <i class="mdi mdi-star"></i> @item.ReviewScore/5
                                    </div>
                                </td>
                                <td>
                                    @if (item.Status)
                                    {
                                        <span class="status-pill status-active">Yayında</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-passive">Taslak</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId" class="btn-icon" title="Düzenle">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <button type="button" onclick="deleteTestimonial('@item.TestimonialId')" class="btn-icon btn-icon-del" title="Sil">
                                            <i class="mdi mdi-delete-outline"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align:center; padding: 50px; color: #888780;">
                                <i class="mdi mdi-comment-off-outline" style="font-size: 40px; display: block; margin-bottom: 10px;"></i>
                                Henüz bir yorum bulunmuyor.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteTestimonial(id) {
            Swal.fire({
                title: 'Referansı Sil?',
                text: "Seçilen müşteri yorumu kalıcı olarak silinecektir.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#a32d2d',
                cancelButtonColor: '#888780',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/Testimonial/DeleteTestimonial/" + id;
                }
            });
        }
    </script>
}