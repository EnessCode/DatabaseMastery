@model List<ResultQuestionDto>
@{
    ViewData["Title"] = "Sıkça Sorulan Sorular";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .faq-page {
        font-family: 'DM Sans', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 4px;
    }

    .page-subtitle {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a18;
        color: #f4f3ef;
        border: none;
        border-radius: 100px;
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.18s ease, transform 0.18s ease;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: #333330;
            color: #f4f3ef;
            transform: translateY(-1px);
        }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .faq-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e8e6e0;
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .faq-card:hover {
            transform: translateX(3px);
            box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        }

    .faq-card-inner {
        display: flex;
        align-items: stretch;
        gap: 0;
    }

    /* Sol: numara şeridi */
    .faq-num-strip {
        width: 52px;
        background: #f8f7f3;
        border-right: 1px solid #f0ede6;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 13px;
        font-weight: 600;
        color: #b4b2a9;
    }

    /* Orta: içerik */
    .faq-content {
        flex: 1;
        padding: 16px 20px;
        min-width: 0;
    }

    .faq-title {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .faq-desc {
        font-size: 12.5px;
        color: #888780;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Sağ: durum + aksiyonlar */
    .faq-right {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 18px;
        border-left: 1px solid #f0ede6;
        flex-shrink: 0;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 500;
        padding: 3px 9px;
        border-radius: 100px;
        white-space: nowrap;
    }

        .status-pill.active {
            background: #eaf3de;
            color: #3b6d11;
        }

        .status-pill.inactive {
            background: #fcebeb;
            color: #a32d2d;
        }

    .status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    .action-group {
        display: flex;
        gap: 6px;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid;
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s ease;
    }

    .btn-icon-edit {
        border-color: #d3d1c7;
        color: #444441;
    }

        .btn-icon-edit:hover {
            background: #f4f3ef;
            color: #1a1a18;
        }

    .btn-icon-del {
        border-color: #f7c1c1;
        color: #a32d2d;
    }

        .btn-icon-del:hover {
            background: #fcebeb;
            color: #791f1f;
        }

    .empty-state {
        padding: 4rem 2rem;
        text-align: center;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
    }

    .empty-icon-wrap {
        width: 64px;
        height: 64px;
        background: #f4f3ef;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 24px;
        color: #b4b2a9;
    }

    .empty-state h5 {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 5px;
    }

    .empty-state p {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .list-footer {
        margin-top: 1rem;
        text-align: right;
        font-size: 12px;
        color: #888780;
    }

        .list-footer strong {
            color: #444441;
            font-weight: 600;
        }
</style>

<div class="faq-page">
    <div class="page-header">
        <div>
            <h3 class="page-title">Sıkça Sorulan Sorular</h3>
            <p class="page-subtitle">Ana sayfada gösterilen SSS içeriklerini yönetin.</p>
        </div>
        <a href="/Question/CreateQuestion" class="btn-add">
            <i class="mdi mdi-plus-circle"></i> Yeni Soru Ekle
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="faq-list">
            @{
                int num = 1;
            }
            @foreach (var item in Model)
            {
                <div class="faq-card">
                    <div class="faq-card-inner">
                        <div class="faq-num-strip">#@num</div>

                        <div class="faq-content">
                            <div class="faq-title" title="@item.Title">@item.Title</div>
                            <div class="faq-desc" title="@item.Description">@item.Description</div>
                        </div>

                        <div class="faq-right">
                            @if (item.Status)
                            {
                                <span class="status-pill active"><span class="status-dot"></span> Aktif</span>
                            }
                            else
                            {
                                <span class="status-pill inactive"><span class="status-dot"></span> Pasif</span>
                            }
                            <div class="action-group">
                                <a href="/Question/UpdateQuestion/@item.QuestionId"
                                   class="btn-icon btn-icon-edit" title="Düzenle">
                                    <i class="mdi mdi-pencil"></i>
                                </a>
                                <button type="button"
                                        onclick="deleteQuestion('@item.QuestionId')"
                                        class="btn-icon btn-icon-del" title="Sil">
                                    <i class="mdi mdi-delete-outline"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                num++;
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon-wrap">
                <i class="mdi mdi-help-circle-outline"></i>
            </div>
            <h5>Henüz Soru Eklenmemiş</h5>
            <p>Sıkça sorulan soruları ekleyerek bu bölümü oluşturmaya başlayabilirsiniz.</p>
        </div>
    }

    <div class="list-footer">
        Toplam Soru: <strong>@Model.Count</strong>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteQuestion(id) {
            Swal.fire({
                title: 'Soruyu Sil?',
                text: "Bu içerik kalıcı olarak silinecektir.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#a32d2d',
                cancelButtonColor: '#888780',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/Question/DeleteQuestion/" + id;
                }
            });
        }
    </script>
}
