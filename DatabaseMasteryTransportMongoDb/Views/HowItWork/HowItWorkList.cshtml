@model List<ResultHowItWorkDto>
@{
    ViewData["Title"] = "Nasıl Çalışır";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .hiw-page {
        font-family: 'DM Sans', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 4px;
    }

    .page-subtitle {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a18;
        color: #f4f3ef;
        border: none;
        border-radius: 100px;
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.18s ease, transform 0.18s ease;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: #333330;
            color: #f4f3ef;
            transform: translateY(-1px);
        }

    /* Timeline list */
    .hiw-timeline {
        position: relative;
        padding-left: 36px;
    }

        .hiw-timeline::before {
            content: '';
            position: absolute;
            left: 19px;
            top: 28px;
            bottom: 28px;
            width: 2px;
            background: repeating-linear-gradient(to bottom, #d3d1c7 0px, #d3d1c7 6px, transparent 6px, transparent 12px);
        }

    .hiw-item {
        position: relative;
        display: flex;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 14px;
    }

        .hiw-item:last-child {
            margin-bottom: 0;
        }

    /* Step number dot */
    .hiw-step-dot {
        position: absolute;
        left: -36px;
        top: 50%;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e8e6e0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 600;
        color: #888780;
        z-index: 1;
        flex-shrink: 0;
    }

    .hiw-card {
        flex: 1;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hiw-card:hover {
            transform: translateX(3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        }

    .hiw-icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #fdf8e8;
        border: 1px solid #f0e6b0;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
    }

        .hiw-icon-wrap img {
            width: 28px;
            height: 28px;
            object-fit: contain;
        }

    .hiw-icon-placeholder {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #f4f3ef;
        border: 1px solid #e8e6e0;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 20px;
        color: #b4b2a9;
    }

    .hiw-text {
        flex: 1;
    }

    .hiw-title {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 3px;
    }

    .hiw-desc {
        font-size: 12.5px;
        color: #888780;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hiw-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 500;
        padding: 3px 9px;
        border-radius: 100px;
        white-space: nowrap;
    }

        .status-pill.active {
            background: #eaf3de;
            color: #3b6d11;
        }

        .status-pill.inactive {
            background: #fcebeb;
            color: #a32d2d;
        }

    .status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    .action-group {
        display: flex;
        gap: 6px;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid;
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s ease;
    }

    .btn-icon-edit {
        border-color: #d3d1c7;
        color: #444441;
    }

        .btn-icon-edit:hover {
            background: #f4f3ef;
            color: #1a1a18;
        }

    .btn-icon-del {
        border-color: #f7c1c1;
        color: #a32d2d;
    }

        .btn-icon-del:hover {
            background: #fcebeb;
            color: #791f1f;
        }

    .empty-state {
        padding: 4rem 2rem;
        text-align: center;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
    }

    .empty-icon-wrap {
        width: 64px;
        height: 64px;
        background: #f4f3ef;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 24px;
        color: #b4b2a9;
    }

    .empty-state h5 {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 5px;
    }

    .empty-state p {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .list-footer {
        margin-top: 1rem;
        text-align: right;
        font-size: 12px;
        color: #888780;
    }

        .list-footer strong {
            color: #444441;
            font-weight: 600;
        }
</style>

<div class="hiw-page">
    <div class="page-header">
        <div>
            <h3 class="page-title">Nasıl Çalışır</h3>
            <p class="page-subtitle">Ana sayfadaki süreç adımlarını yönetin.</p>
        </div>
        <a href="/HowItWork/CreateHowItWork" class="btn-add">
            <i class="mdi mdi-plus-circle"></i> Yeni Adım Ekle
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="hiw-timeline">
            @{
                int step = 1;
            }
            @foreach (var item in Model)
            {
                <div class="hiw-item">
                    <div class="hiw-step-dot">@step</div>
                    <div class="hiw-card">
                        @if (!string.IsNullOrEmpty(item.IconUrl))
                        {
                            <div class="hiw-icon-wrap">
                                <img src="@item.IconUrl" alt="@item.Title" onerror="this.parentElement.style.display='none'; this.parentElement.nextElementSibling.style.display='flex';" />
                            </div>
                            <div class="hiw-icon-placeholder" style="display:none;">
                                <i class="mdi mdi-image-off-outline"></i>
                            </div>
                        }
                        else
                        {
                            <div class="hiw-icon-placeholder">
                                <i class="mdi mdi-help-circle-outline"></i>
                            </div>
                        }

                        <div class="hiw-text">
                            <div class="hiw-title">@item.Title</div>
                            <div class="hiw-desc" title="@item.Description">@item.Description</div>
                        </div>

                        <div class="hiw-right">
                            @if (item.Status)
                            {
                                <span class="status-pill active"><span class="status-dot"></span> Aktif</span>
                            }
                            else
                            {
                                <span class="status-pill inactive"><span class="status-dot"></span> Pasif</span>
                            }
                            <div class="action-group">
                                <a href="/HowItWork/UpdateHowItWork/@item.HowItWorkId" class="btn-icon btn-icon-edit" title="Düzenle">
                                    <i class="mdi mdi-pencil"></i>
                                </a>
                                <button type="button" onclick="deleteStep('@item.HowItWorkId')" class="btn-icon btn-icon-del" title="Sil">
                                    <i class="mdi mdi-delete-outline"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                step++;
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon-wrap">
                <i class="mdi mdi-lightbulb-off-outline"></i>
            </div>
            <h5>Henüz Adım Eklenmemiş</h5>
            <p>Süreç adımlarını ekleyerek nasıl çalışır bölümünü oluşturabilirsiniz.</p>
        </div>
    }

    <div class="list-footer">
        Toplam Adım: <strong>@Model.Count</strong>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteStep(id) {
            Swal.fire({
                title: 'Adımı Sil?',
                text: "Bu adım kalıcı olarak silinecektir.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#a32d2d',
                cancelButtonColor: '#888780',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/HowItWork/DeleteHowItWork/" + id;
                }
            });
        }
    </script>
}
