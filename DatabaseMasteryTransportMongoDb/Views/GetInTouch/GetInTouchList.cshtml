@model List<ResultGetInTouchDto>
@{
    ViewData["Title"] = "İletişime Geç";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .git-page {
        font-family: 'DM Sans', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 4px;
    }

    .page-subtitle {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a18;
        color: #f4f3ef;
        border: none;
        border-radius: 100px;
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.18s ease, transform 0.18s ease;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: #333330;
            color: #f4f3ef;
            transform: translateY(-1px);
        }

    .git-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .git-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .git-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(0,0,0,0.07);
        }

    .git-card-top {
        display: flex;
    }

    .git-thumb-wrap {
        width: 200px;
        flex-shrink: 0;
    }

    .git-thumb {
        width: 100%;
        height: 100%;
        min-height: 160px;
        object-fit: cover;
        display: block;
    }

    .git-thumb-placeholder {
        width: 100%;
        height: 100%;
        min-height: 160px;
        background: #f4f3ef;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #b4b2a9;
        font-size: 32px;
    }

    .git-main {
        flex: 1;
        padding: 20px 22px;
        border-left: 1px solid #f0ede6;
    }

    .git-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 6px;
    }

    .git-desc {
        font-size: 13px;
        color: #888780;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .git-sub-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid #f4f3ef;
    }

    .git-sub-item {
        padding: 14px 22px;
        border-right: 1px solid #f4f3ef;
    }

        .git-sub-item:last-of-type {
            border-right: none;
        }

    .git-sub-label {
        font-size: 10px;
        font-weight: 500;
        color: #b4b2a9;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 4px;
    }

    .git-sub-title {
        font-size: 13px;
        font-weight: 600;
        color: #444441;
        margin-bottom: 3px;
    }

    .git-sub-desc {
        font-size: 12px;
        color: #888780;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .git-footer {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 12px 22px 14px;
        border-top: 1px solid #f4f3ef;
    }

    .btn-action {
        padding: 7px 18px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: background 0.15s ease;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-action-edit {
        background: transparent;
        border-color: #d3d1c7;
        color: #444441;
    }

        .btn-action-edit:hover {
            background: #f4f3ef;
            color: #1a1a18;
        }

    .btn-action-del {
        background: transparent;
        border-color: #f7c1c1;
        color: #a32d2d;
    }

        .btn-action-del:hover {
            background: #fcebeb;
            color: #791f1f;
        }

    .empty-state {
        padding: 4rem 2rem;
        text-align: center;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
    }

    .empty-icon-wrap {
        width: 64px;
        height: 64px;
        background: #f4f3ef;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        font-size: 24px;
        color: #b4b2a9;
    }

    .empty-state h5 {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 5px;
    }

    .empty-state p {
        font-size: 13px;
        color: #888780;
        margin: 0;
    }

    .list-footer {
        margin-top: 1rem;
        text-align: right;
        font-size: 12px;
        color: #888780;
    }

        .list-footer strong {
            color: #444441;
            font-weight: 600;
        }

    .status-info {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: #f0fdf4; 
        color: #166534; 
        border: 1px solid #bbf7d0;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 500;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

        .status-info i {
            font-size: 1.1rem;
        }
</style>
<div class="git-page">
    <div class="page-header">
        <div>
            <h3 class="page-title">İletişime Geç</h3>
            <p class="page-subtitle">Ana sayfada gösterilen iletişim bölümü içeriklerini yönetin.</p>
        </div>

        @if (Model != null && Model.Count == 0)
        {
            <a href="/GetInTouch/CreateGetInTouch" class="btn-add">
                <i class="mdi mdi-plus-circle"></i> Yeni İçerik Ekle
            </a>
        }
        else
        {
            <div class="status-info">
                <i class="mdi mdi-check-decagram"></i>
                İletişim içeriği yayında
            </div>
        }
    </div>
    <div class="git-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="git-card">
                    <div class="git-card-top">
                        <div class="git-thumb-wrap">
                            <img src="@item.ImageUrl"
                                 class="git-thumb"
                                 alt="@item.Title"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                            <div class="git-thumb-placeholder" style="display:none;">
                                <i class="mdi mdi-image-off-outline"></i>
                            </div>
                        </div>
                        <div class="git-main">
                            <div class="git-title">@item.Title</div>
                            <div class="git-desc" title="@item.Description">@item.Description</div>
                        </div>
                    </div>

                    <div class="git-sub-row">
                        <div class="git-sub-item">
                            <div class="git-sub-label">Alt Başlık 1</div>
                            <div class="git-sub-title">@item.SubTitle1</div>
                            <div class="git-sub-desc">@item.SubDescription1</div>
                        </div>
                        <div class="git-sub-item">
                            <div class="git-sub-label">Alt Başlık 2</div>
                            <div class="git-sub-title">@item.SubTitle2</div>
                            <div class="git-sub-desc">@item.SubDescription2</div>
                        </div>
                    </div>

                    <div class="git-footer">
                        <a href="/GetInTouch/UpdateGetInTouch/@item.GetInTouchId" class="btn-action btn-action-edit">
                            <i class="mdi mdi-pencil"></i> Düzenle
                        </a>
                        <button type="button" onclick="deleteGetInTouch('@item.GetInTouchId')" class="btn-action btn-action-del">
                            <i class="mdi mdi-delete-outline"></i> Sil
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon-wrap">
                    <i class="mdi mdi-phone-off-outline"></i>
                </div>
                <h5>Henüz İçerik Eklenmemiş</h5>
                <p>Yeni içerik ekleyerek iletişim bölümünü oluşturmaya başlayabilirsiniz.</p>
            </div>
        }
    </div>

    <div class="list-footer">
        Toplam Kayıt: <strong>@Model.Count</strong>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteGetInTouch(id) {
            Swal.fire({
                title: 'İçeriği Sil?',
                text: "Bu içerik kalıcı olarak silinecektir.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#a32d2d',
                cancelButtonColor: '#888780',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/GetInTouch/DeleteGetInTouch/" + id;
                }
            });
        }
    </script>
}
