@model List<ResultTestimonialDto>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/7.2.96/css/materialdesignicons.min.css">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">

<section class="section mt-50 bg-customers-say">
    <div class="container">
        <h2 class="title-favicon color-white mb-20 title-padding-left">Müşterilerimiz Ne Diyor</h2>
        <p class="font-lg color-white pl-55">
            Hizmetlerimizden faydalanan müşterilerimizin deneyimlerini keşfedin <br class="d-none d-lg-block">
            ve sağladığımız değeri yakından görün.
        </p>
    </div>

    <div class="box-slide-customers mt-50">
        <div class="box-swiper">
            <div class="swiper-container swiper-group-3-customers pb-50">
                <div class="swiper-wrapper">
                    @foreach (var item in Model)
                    {
                        <div class="swiper-slide">
                            <div class="card-testimonial-custom">
                                <div class="author-header">
                                    <img src="@item.ImageUrl" alt="@item.NameSurname" class="customer-avatar">
                                    <div class="author-meta">
                                        <h4 class="customer-name">@item.NameSurname</h4>
                                        <p class="customer-title">@item.Title</p>
                                    </div>
                                </div>

                                <div class="testimonial-body">
                                    <p class="review-text">@item.ReviewDetail</p>
                                </div>

                                <div class="info-footer-dark">
                                    <div class="footer-left">
                                        <div class="star-container">
                                            <div class="star-base">
                                                <i class="mdi mdi-star"></i><i class="mdi mdi-star"></i><i class="mdi mdi-star"></i><i class="mdi mdi-star"></i><i class="mdi mdi-star"></i>
                                            </div>
                                            <div class="star-fill" style="width: @(item.ReviewScore * 20)%;">
                                                <i class="mdi mdi-star"></i><i class="mdi mdi-star"></i><i class="mdi mdi-star"></i><i class="mdi mdi-star"></i><i class="mdi mdi-star"></i>
                                            </div>
                                        </div>
                                        <span class="support-label">Müşteri Desteği</span>
                                    </div>
                                    <div class="footer-right">
                                        <span class="score-text">Puan: @item.ReviewScore / 5</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="box-pagination-customers">
                    <div class="swiper-button-prev swiper-button-prev-customers swiper-button-prev-style-1">
                        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path></svg>
                    </div>
                    <div class="swiper-button-next swiper-button-next-customers swiper-button-next-style-1">
                        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .card-testimonial-custom {
        background: #fff;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        height: 100%;
        width: 100%;
        overflow: hidden;
        border: 1px solid #e8e6e0;
        font-family: 'DM Sans', sans-serif;
    }

    /* Profil Kısmı */
    .author-header {
        padding: 25px 25px 15px 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .customer-avatar {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        object-fit: cover;
    }

    .customer-name {
        color: #b89650;
        font-size: 19px;
        font-weight: 700;
        margin: 0;
    }

    .customer-title {
        color: #888;
        font-size: 14px;
        margin: 2px 0 0 0;
    }

    .testimonial-body {
        padding: 0 25px 30px 25px;
        flex-grow: 1;
    }

    .review-text {
        font-size: 15.5px;
        color: #555;
        line-height: 1.6;
        margin: 0;
    }

    .info-footer-dark {
        background: #00405b;
        padding: 18px 25px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .star-container {
        position: relative;
        display: inline-block;
        font-size: 15px;
        margin-bottom: 4px;
    }

    .star-base {
        color: rgba(255, 255, 255, 0.15); 
        letter-spacing: 2px;
    }

    .star-fill {
        position: absolute;
        top: 0;
        left: 0;
        color: #ffb400; 
        overflow: hidden;
        white-space: nowrap;
        letter-spacing: 2px;
    }

    .support-label {
        color: #fff;
        display: block;
        font-size: 14px;
        font-weight: 500;
    }

    .score-text {
        color: rgba(255, 255, 255, 0.8);
        font-size: 12px;
        font-weight: 400;
    }

    .bg-customers-say .swiper-slide {
        height: auto !important;
        display: flex !important;
    }
</style>