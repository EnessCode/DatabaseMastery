@model List<ResultQuestionDto>

<section class="section pt-80 mb-70 bg-faqs">
	<div class="container">
		<div class="row">
			<div class="col-lg-6">
				<div class="box-faqs-left">
					<h2 class="title-favicon mb-20">Sıkça Sorulan Sorular</h2>
					<p class="font-md color-grey-700 mb-50">Merak ettiğiniz bir konu mu var? Sıkça sorulan soruları inceleyebilir veya yardım için destek ekibimizle iletişime geçebilirsiniz.</p>
					<div class="box-gallery-faqs">
						<div class="image-top"> <img src="/templates/assets/imgs/page/homepage1/img-faq1.png" alt="lojistik yardim"></div>
						<div class="image-bottom">
							<div class="image-faq-1"> <img src="/templates/assets/imgs/page/homepage1/img-faq2.png" alt="kargo destek"></div>
							<div class="image-faq-2"> <img src="/templates/assets/imgs/page/homepage1/img-faq3.png" alt="musteri hizmetleri"></div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-lg-6">
				<div class="box-accordion">
					<div class="accordion custom-dynamic-accordion" id="accordionFAQ">
						@{
							int count = 0;
						}
						@foreach (var item in Model)
						{
							count++;
							<div class="accordion-item mb-15">
								<h5 class="accordion-header" id="heading-@count">
									<button class="accordion-button text-heading-5 collapsed" type="button"
											data-bs-toggle="collapse"
											data-bs-target="#collapse-@count"
											aria-expanded="false"
											aria-controls="collapse-@count">
										@item.Title
									</button>
								</h5>
								<div id="collapse-@count"
									 class="accordion-collapse collapse"
									 aria-labelledby="heading-@count"
									 data-bs-parent="#accordionFAQ">
									<div class="accordion-body">
										@item.Description
									</div>
								</div>
							</div>
						}
					</div>
					<div class="line-border mt-50 mb-50"></div>
					<h3 class="color-brand-2">Daha fazla yardıma mı ihtiyacınız var?</h3>
					<div class="mt-20">
						<a class="btn btn-brand-1-big mr-20" href="contact.html">Bize Ulaşın</a>
						<a class="btn btn-link-medium" href="#">
							Daha Fazla Bilgi
							<svg class="w-6 h-6 icon-16 ml-5" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.custom-dynamic-accordion .accordion-item {
		border: none;
		background: transparent;
	}

	.custom-dynamic-accordion .accordion-button.collapsed {
		background-color: #004a74 !important;
		color: #ffffff !important; 
		border-radius: 4px !important;
	}

		.custom-dynamic-accordion .accordion-button.collapsed::after {
			filter: brightness(0) saturate(100%) invert(84%) sepia(54%) saturate(932%) 
		}

	.custom-dynamic-accordion .accordion-button:not(.collapsed) {
		background-color: #ffc800 !important;
		color: #002b49 !important; 
		border-bottom-left-radius: 0px !important;
		border-bottom-right-radius: 0px !important;
		box-shadow: none !important;
	}

		.custom-dynamic-accordion .accordion-button:not(.collapsed)::after {
			filter: brightness(0) saturate(100%) invert(11%) sepia(45%) saturate(4832%) 
		}

	.custom-dynamic-accordion .accordion-button {
		font-size: 16px;
		font-weight: 600;
		padding: 18px 25px;
		transition: all 0.25s ease-in-out; 
	}

	.custom-dynamic-accordion .accordion-body {
		padding: 20px 25px;
		background-color: #ffffff;
		color: #444444;
		font-size: 14.5px;
		line-height: 1.6;
		border-left: 1px solid #e8e6e0;
		border-right: 1px solid #e8e6e0;
		border-bottom: 1px solid #e8e6e0;
		border-bottom-left-radius: 4px;
		border-bottom-right-radius: 4px;
	}

	.mb-15 {
		margin-bottom: 15px !important;
	}
</style>