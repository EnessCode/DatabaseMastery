<div class="box-form-contact-leading">
    <div class="row">
        <div class="col-lg-8">
            <h2 class="title-favicon color-brand-2 mb-15">Nakliye Hesapla</h2>
            <p class="font-md color-grey-700 mb-25">Toplam fiyatı almak için lütfen tüm bilgileri doldurun.</p>

            <div class="row align-items-center" id="calculateShipping">
                <div class="col-lg-6">
                    <div class="form-group">
                        <select class="form-control" id="hizmetSecin">
                            <option value="">Hizmet Seçin</option>
                            <option value="500">Kurye Teslimatı (Taban: 500 TL)</option>
                            <option value="1200">Parsiyel Taşımacılık (Taban: 1200 TL)</option>
                            <option value="2500">Komple Araç Nakliyesi (Taban: 2500 TL)</option>
                            <option value="4000">Evden Eve Nakliyat (Taban: 4000 TL)</option>
                        </select>
                    </div>
                </div>
                <div class="col-lg-3">
                    <div class="form-group">
                        <input class="form-control" type="text" id="boyutlar" placeholder="Boyutlar (ExBoyxYük)">
                    </div>
                </div>
                <div class="col-lg-3">
                    <div class="form-group">
                        <input class="form-control" type="number" id="agirlik" placeholder="Ağırlık (kg)">
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="form-group">
                        <select class="form-control" id="cikisNoktasi">
                            <option value="">Çıkış Noktası</option>
                            <option value="Istanbul">İstanbul</option>
                            <option value="Ankara">Ankara</option>
                            <option value="Izmir">İzmir</option>
                            <option value="Bursa">Bursa</option>
                            <option value="Antalya">Antalya</option>
                        </select>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="form-group">
                        <select class="form-control" id="teslimatNoktasi">
                            <option value="">Teslimat Noktası</option>
                            <option value="Istanbul">İstanbul</option>
                            <option value="Ankara">Ankara</option>
                            <option value="Izmir">İzmir</option>
                            <option value="Bursa">Bursa</option>
                            <option value="Antalya">Antalya</option>
                        </select>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="form-group">
                        <select class="form-control" id="urunCinsi">
                            <option value="">Ürün Cinsi (Emtia)</option>
                            <option value="Koli">Koli / Paket</option>
                            <option value="Palet">Paletli Ürün</option>
                            <option value="Mobilya">Mobilya / Ev Eşyası</option>
                            <option value="Elektronik">Elektronik Cihaz</option>
                        </select>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="form-group">
                        <select class="form-control" id="malMiktari">
                            <option value="">Mal Miktarı / Adet</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                        </select>
                    </div>
                </div>

                <div class="col-lg-12 mb-20">
                    <div class="form-group">
                        <strong class="font-sm-bold color-grey-900">Ek Hizmetler</strong>
                        <div class="row mt-10 box-cb-form">
                            <div class="col-lg-4 col-md-4">
                                <div class="form-group">
                                    <input class="cd-form" type="checkbox" id="ekspresTeslimat" value="450"> Ekspres Teslimat (+450 TL)
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-4">
                                <div class="form-group">
                                    <input class="cd-form" type="checkbox" id="sigortaEkle" value="250"> Sigorta Ekle (+250 TL)
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-4">
                                <div class="form-group">
                                    <input class="cd-form" type="checkbox" id="paketleme" value="150"> Paketleme (+150 TL)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-12 mb-20" id="sonucAlani">
                    <div class="alert alert-success" style="background-color: #f4fdf8; border-color: #06a055; color: #06a055; padding: 15px; border-radius: 4px;">
                        <strong>Tahmini Toplam Maliyet: </strong> <span id="toplamTutar" style="font-size: 18px; font-weight: bold;">0 TL</span>
                    </div>
                </div>

                <div class="col-lg-12">
                    <a class="btn btn-brand-1-big" href="/Default/Index/#contact">
                        Bizimle İletişime Geçin
                        <svg class="w-6 h-6 icon-16 ml-5" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="box-image-contact"> <img src="/templates/assets/imgs/page/homepage1/img-contact.png" alt="transp"></div>
        </div>
    </div>
</div>

<script>
    function otomatikMaliyetHesapla() {
        const hizmetBedeli = parseFloat(document.getElementById('hizmetSecin').value) || 0;
        const agirlik = parseFloat(document.getElementById('agirlik').value) || 0;
        const adet = parseInt(document.getElementById('malMiktari').value) || 1;
        const cikis = document.getElementById('cikisNoktasi').value;
        const teslimat = document.getElementById('teslimatNoktasi').value;

        if (!hizmetBedeli || !cikis || !teslimat) {
            document.getElementById('toplamTutar').innerText = '0 TL';
            return;
        }

        let toplam = (hizmetBedeli + (agirlik * 15)) * adet;

        if (document.getElementById('ekspresTeslimat').checked) {
            toplam += parseFloat(document.getElementById('ekspresTeslimat').value);
        }
        if (document.getElementById('sigortaEkle').checked) {
            toplam += parseFloat(document.getElementById('sigortaEkle').value);
        }
        if (document.getElementById('paketleme').checked) {
            toplam += parseFloat(document.getElementById('paketleme').value);
        }

        document.getElementById('toplamTutar').innerText = toplam.toLocaleString('tr-TR') + ' TL';
    }

    const formKonteynir = document.getElementById('calculateShipping');
    formKonteynir.addEventListener('input', otomatikMaliyetHesapla);
    formKonteynir.addEventListener('change', otomatikMaliyetHesapla);
</script>