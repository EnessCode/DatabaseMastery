@model List<ResultShipmentTrackingDto>
@{
	ViewData["Title"] = "Kargo Hareket Detayları";
	Layout = "~/Views/AdminLayout/Index.cshtml";
	string trackingNo = ViewBag.TrackingNumber;
}

<style>
	@@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

	.tracking-page {
		font-family: 'DM Sans', sans-serif;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.page-title {
		font-size: 22px;
		font-weight: 600;
		color: #1a1a18;
		margin-bottom: 4px;
	}

	.page-subtitle {
		font-size: 13px;
		color: #888780;
		margin: 0;
	}

	.btn-action-main {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: #1a1a18;
		color: #f4f3ef;
		border: none;
		border-radius: 100px;
		padding: 10px 20px;
		font-size: 13px;
		font-weight: 500;
		text-decoration: none;
		transition: background 0.18s ease, transform 0.18s ease;
		white-space: nowrap;
	}

		.btn-action-main:hover {
			background: #333330;
			color: #f4f3ef;
			transform: translateY(-1px);
		}

	.btn-action-back {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: transparent;
		color: #444441;
		border: 1px solid #d3d1c7;
		border-radius: 100px;
		padding: 9px 18px;
		font-size: 13px;
		font-weight: 500;
		text-decoration: none;
		transition: background 0.15s ease;
	}

		.btn-action-back:hover {
			background: #f4f3ef;
			color: #1a1a18;
		}

	.header-actions-group {
		display: flex;
		gap: 10px;
	}

	.info-card {
		background: #f8f7f3;
		border-radius: 12px;
		border: 1px solid #e8e6e0;
		padding: 16px 20px;
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.info-card-icon {
		font-size: 24px;
		color: #444441;
	}

	.info-card-text h5 {
		font-size: 14px;
		font-weight: 600;
		color: #1a1a18;
		margin-bottom: 2px;
	}

	.info-card-text p {
		font-size: 12.5px;
		color: #888780;
		margin: 0;
	}

	.timeline-card {
		background: #fff;
		border-radius: 14px;
		border: 1px solid #e8e6e0;
		padding: 26px;
	}

	.timeline-container {
		position: relative;
		padding-left: 32px;
		margin-left: 8px;
		border-left: 2px solid #e8e6e0;
	}

	.timeline-item {
		position: relative;
		margin-bottom: 30px;
	}

		.timeline-item:last-child {
			margin-bottom: 0;
		}

	.timeline-dot {
		position: absolute;
		left: -40px;
		top: 2px;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #1a1a18;
		border: 3px solid #fff;
		box-shadow: 0 0 0 3px rgba(26,26,24,0.1);
	}

	.timeline-item:first-child .timeline-dot {
		background: #3b6d11;
		box-shadow: 0 0 0 3px rgba(59,109,17,0.2);
	}

	.timeline-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 6px;
		gap: 15px;
	}

	.timeline-status {
		font-size: 14px;
		font-weight: 600;
		color: #1a1a18;
	}

	.timeline-date {
		font-size: 12px;
		color: #888780;
		white-space: nowrap;
	}

	.timeline-location {
		font-size: 12.5px;
		font-weight: 500;
		color: #444441;
		margin-bottom: 4px;
		display: flex;
		align-items: center;
		gap: 4px;
	}

		.timeline-location i {
			color: #a32d2d;
		}

	.timeline-desc {
		font-size: 13px;
		color: #666560;
		margin: 0 0 10px 0;
		line-height: 1.5;
	}

	.timeline-actions {
		display: flex;
		gap: 14px;
	}

	.btn-link-edit {
		font-size: 12px;
		font-weight: 500;
		color: #185FA5;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 3px;
	}

		.btn-link-edit:hover {
			text-decoration: underline;
		}

	.btn-link-del {
		font-size: 12px;
		font-weight: 500;
		color: #a32d2d;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 3px;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
	}

		.btn-link-del:hover {
			text-decoration: underline;
		}

	.empty-state {
		padding: 4rem 2rem;
		text-align: center;
	}

	.empty-icon-wrap {
		width: 64px;
		height: 64px;
		background: #f4f3ef;
		border-radius: 50%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1rem;
		font-size: 24px;
		color: #b4b2a9;
	}

	.empty-state h5 {
		font-size: 15px;
		font-weight: 600;
		color: #1a1a18;
		margin-bottom: 5px;
	}

	.empty-state p {
		font-size: 13px;
		color: #888780;
		margin: 0;
	}
</style>

<div class="tracking-page">
	<div class="page-header">
		<div>
			<h3 class="page-title">Kargo Hareketleri</h3>
			<p class="page-subtitle">Seçili kargo kaydına ait zamansal konum ve durum geçmişini yönetin.</p>
		</div>
		<div class="header-actions-group">
			<a href="/Shipment/ShipmentList" class="btn-action-back">
				<i class="mdi mdi-arrow-left"></i> Listeye Dön
			</a>
			<a href="/ShipmentTracking/AddTracking?trackingNumber=@trackingNo" class="btn-action-main">
				<i class="mdi mdi-map-marker-plus"></i> Yeni Hareket Ekle
			</a>
		</div>
	</div>

	<div class="info-card">
		<div class="info-card-icon">
			<i class="mdi mdi-barcode-scan"></i>
		</div>
		<div class="info-card-text">
			<h5>Takip Numarası: @trackingNo</h5>
			<p>Bu numaraya ait toplam <strong>@Model.Count</strong> hareket kaydı bulunmaktadır.</p>
		</div>
	</div>

	<div class="timeline-card">
		@if (Model != null && Model.Any())
		{
			<div class="timeline-container">
				@for (int i = 0; i < Model.Count; i++)
				{
					var item = Model[i];
					<div class="timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-header">
							<span class="timeline-status">@item.TrackingStatus</span>
							<span class="timeline-date">@item.EventDate.ToString("dd MMM yyyy, HH:mm")</span>
						</div>
						<div class="timeline-location">
							<i class="mdi mdi-map-marker"></i> @item.Location
						</div>
						<p class="timeline-desc">@item.Description</p>

						<div class="timeline-actions">
							<a href="/ShipmentTracking/UpdateTracking?trackingNumber=@trackingNo&index=@i" class="btn-link-edit">
								<i class="mdi mdi-pencil-outline"></i> Düzenle
							</a>
							<button type="button" onclick="confirmDeleteTracking('@trackingNo', '@i')" class="btn-link-del">
								<i class="mdi mdi-delete-outline"></i> Sil
							</button>
						</div>
					</div>
				}
			</div>
		}
		else
		{
			<div class="empty-state">
				<div class="empty-icon-wrap">
					<i class="mdi mdi-map-marker-off"></i>
				</div>
				<h5>Henüz Hareket Kaydı Yok</h5>
				<p>Kargonun lojistik sürecini başlatmak için yukarıdan "Yeni Hareket Ekle" butonunu kullanabilirsiniz.</p>
			</div>
		}
	</div>
</div>

@section Scripts {
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
	<script>
		@if (TempData["Success"] != null)
		{
					<text>
						Swal.fire({
							icon: 'success',
							title: 'Başarılı!',
							html: '@Html.Raw(TempData["Success"])',
							confirmButtonColor: '#1a1a18',
							timer: 3000
						});
					</text>
		}

		function confirmDeleteTracking(trackingNumber, index) {
					Swal.fire({
						title: 'Hareket Kaydını Sil?',
						text: 'Bu kargo hareketi kalıcı olarak silinecektir.',
						icon: 'warning',
						showCancelButton: true,
						confirmButtonColor: '#a32d2d',
						cancelButtonColor:  '#888780',
						confirmButtonText:  'Evet, Sil',
						cancelButtonText:   'Vazgeç'
					}).then((result) => {
						if (result.isConfirmed) {
							window.location.href = `/ShipmentTracking/DeleteTracking?trackingNumber=${trackingNumber}&index=${index}`;
						}
					});
				}
	</script>
}