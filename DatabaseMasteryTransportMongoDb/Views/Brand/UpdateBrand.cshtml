@model GetBrandByIdDto
@{
    ViewData["Title"] = "Marka Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

    .update-brand-page {
        font-family: 'DM Sans', sans-serif;
    }

    .form-card {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #e8e6e0;
        overflow: hidden;
        max-width: 820px;
        margin: 0 auto;
    }

    .form-card-header {
        padding: 20px 26px 18px;
        border-bottom: 1px solid #f0ede6;
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }

    .form-header-icon {
        width: 42px;
        height: 42px;
        background: #f4f3ef;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .form-header-icon i {
            font-size: 20px;
            color: #444441;
        }

    .form-header-text h5 {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a18;
        margin-bottom: 3px;
    }

    .form-header-text p {
        font-size: 12.5px;
        color: #888780;
        margin: 0;
    }

    .form-card-body {
        padding: 26px;
    }

    .form-field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #444441;
        margin-bottom: 7px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .form-field-input {
        width: 100%;
        padding: 10px 14px;
        border-radius: 9px;
        border: 1px solid #d3d1c7;
        font-size: 13.5px;
        color: #1a1a18;
        background: #ffffff;
        font-family: 'DM Sans', sans-serif;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
        outline: none;
    }

        .form-field-input:focus {
            border-color: #888780;
            box-shadow: 0 0 0 3px rgba(136, 135, 128, 0.08);
        }

        .form-field-input::placeholder {
            color: #b4b2a9;
        }

    .input-icon-wrap {
        position: relative;
    }

        .input-icon-wrap .input-prefix-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 16px;
            color: #888780;
            pointer-events: none;
        }

        .input-icon-wrap .form-field-input {
            padding-left: 38px;
        }

    .toggle-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 14px;
        background: #f8f7f3;
        border-radius: 9px;
        border: 1px solid #e8e6e0;
        height: 42px;
    }

        .toggle-row .form-check-input {
            width: 36px;
            height: 20px;
            cursor: pointer;
            flex-shrink: 0;
        }

        .toggle-row .form-check-label {
            font-size: 13px;
            color: #444441;
            cursor: pointer;
            margin: 0;
        }

    .logo-preview-box {
        margin-top: 14px;
        background: #f8f7f3;
        border-radius: 10px;
        border: 1px dashed #d3d1c7;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: border-color 0.2s ease;
    }

        .logo-preview-box.updated {
            border-color: #9FE1CB;
            background: #f4fbf8;
        }

    .logo-preview-slot {
        width: 68px;
        height: 68px;
        background: #ffffff;
        border-radius: 10px;
        border: 1px solid #e8e6e0;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
    }

        .logo-preview-slot img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

    .logo-preview-info {
        font-size: 12.5px;
        color: #888780;
        line-height: 1.7;
    }

    .logo-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 500;
        padding: 3px 9px;
        border-radius: 100px;
        margin-top: 4px;
    }

        .logo-badge.current {
            background: #e6f1fb;
            color: #185FA5;
        }

        .logo-badge.new {
            background: #eaf3de;
            color: #3b6d11;
        }

    .logo-badge-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
    }

    .form-divider {
        border: none;
        border-top: 1px solid #f0ede6;
        margin: 24px 0;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .btn-form-cancel {
        padding: 10px 22px;
        border-radius: 9px;
        border: 1px solid #d3d1c7;
        background: transparent;
        color: #444441;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: background 0.15s ease;
    }

        .btn-form-cancel:hover {
            background: #f4f3ef;
            color: #1a1a18;
        }

    .btn-form-save {
        padding: 10px 26px;
        border-radius: 9px;
        border: none;
        background: #1a1a18;
        color: #f4f3ef;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: background 0.15s ease, transform 0.15s ease;
    }

        .btn-form-save:hover {
            background: #333330;
            transform: translateY(-1px);
        }
</style>

<div class="update-brand-page">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-header-icon">
                <i class="mdi mdi-tag-edit-outline"></i>
            </div>
            <div class="form-header-text">
                <h5>Marka Bilgilerini Güncelle</h5>
                <p>İş ortağına ait isim, logo ve görünürlük durumunu buradan düzenleyebilirsiniz.</p>
            </div>
        </div>

        <div class="form-card-body">
            <form method="post">
                <input type="hidden" asp-for="BrandId" />

                <div class="row g-4">

                    <div class="col-md-8">
                        <label class="form-field-label">Marka / Şirket Adı</label>
                        <input type="text"
                               asp-for="BrandName"
                               class="form-field-input"
                               placeholder="Marka adını giriniz..."
                               required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-field-label">Görünürlük Durumu</label>
                        <div class="toggle-row">
                            <input class="form-check-input"
                                   type="checkbox"
                                   asp-for="IsStatus"
                                   id="statusSwitch" />
                            <label class="form-check-label" for="statusSwitch">Ana sayfada yayınlansın</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-field-label">Logo URL</label>
                        <div class="input-icon-wrap">
                            <i class="mdi mdi-link-variant input-prefix-icon"></i>
                            <input type="text"
                                   asp-for="ImageUrl"
                                   id="logoUrlInput"
                                   class="form-field-input"
                                   required />
                        </div>

                        <div id="logoPreviewContainer" class="logo-preview-box">
                            <div class="logo-preview-slot">
                                <img src="@Model.ImageUrl" id="logoPreview" alt="Marka Logo" />
                            </div>
                            <div class="logo-preview-info">
                                <span id="previewLabel">Mevcut logo</span><br>
                                <span id="logoBadge" class="logo-badge current">
                                    <span class="logo-badge-dot"></span> Kayıtlı
                                </span>
                            </div>
                        </div>
                    </div>

                </div>

                <hr class="form-divider" />

                <div class="form-actions">
                    <a href="/Brand/BrandList" class="btn-form-cancel">Vazgeç</a>
                    <button type="submit" class="btn-form-save">
                        <i class="mdi mdi-check-all"></i> Değişiklikleri Uygula
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const urlInput = document.getElementById('logoUrlInput');
        const previewImg = document.getElementById('logoPreview');
        const previewContainer = document.getElementById('logoPreviewContainer');
        const previewLabel = document.getElementById('previewLabel');
        const logoBadge = document.getElementById('logoBadge');

        urlInput.addEventListener('input', function () {
            const url = this.value.trim();
            if (url) {
                previewImg.src = url;
                previewContainer.classList.add('updated');
                previewLabel.textContent = 'Yeni logo algılandı';
                logoBadge.className = 'logo-badge new';
                logoBadge.innerHTML = '<span class="logo-badge-dot"></span> Güncellendi';
            } else {
                previewContainer.classList.remove('updated');
                previewLabel.textContent = 'Mevcut logo';
                logoBadge.className = 'logo-badge current';
                logoBadge.innerHTML = '<span class="logo-badge-dot"></span> Kayıtlı';
            }
        });

        previewImg.onerror = function () {
            previewContainer.classList.remove('updated');
            previewLabel.textContent = 'Geçersiz URL';
            logoBadge.className = 'logo-badge current';
            logoBadge.innerHTML = '<span class="logo-badge-dot"></span> Hata';
        };
    </script>
}
